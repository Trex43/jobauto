# JobAuto Environment Variables Template
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED VARIABLES (Must be set before deployment)
# =============================================================================

# Database
DATABASE_URL=postgresql://jobauto:password@localhost:5432/jobauto?schema=public

# JWT Secrets (Generate strong random strings: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# =============================================================================
# PAYMENT - STRIPE (Required for subscriptions)
# =============================================================================

# Stripe API Keys (Get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs (Get from Stripe Dashboard → Products)
STRIPE_PRICE_PROFESSIONAL=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# AI - OPENAI (Optional - enables AI features)
# =============================================================================

# OpenAI API Key (Get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# EMAIL - RESEND (Optional - enables transactional email)
# =============================================================================

# Resend API Key (Get from https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email Configuration
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=JobAuto

# =============================================================================
# JOB PORTALS (API Keys where required)
# =============================================================================

# Adzuna (Get from https://developer.adzuna.com/ authenticate)
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key

# USAJobs (Get from https://developer.usajobs.gov/)
USAJOBS_API_KEY=your_usajobs_key

# Jooble (Get from https://ru.jooble.org/api/about)
JOOBLE_API_KEY=your_jooble_key

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Node Environment
NODE_ENV=development

# Server Port
PORT=5000

# Frontend URL (For CORS)
CLIENT_URL=http://localhost:5173

# =============================================================================
# REDIS (For job queues)
# =============================================================================

REDIS_URL=redis://redis:6379

# =============================================================================
# OPTIONAL: LINKEDIN (Requires LinkedIn account with Premium)
# =============================================================================

# Note: LinkedIn integration is in development
# LINKEDIN_EMAIL=your_email
# LINKEDIN_PASSWORD=your_password

# =============================================================================
# OPTIONAL: MONITORING
# =============================================================================

# Sentry DSN (Get from https://sentry.io/settings/)
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxx

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Skip email verification for testing
# SKIP_EMAIL_VERIFICATION=true
# SEED_DATABASE=true
