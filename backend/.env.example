# Backend Environment Variables
# Copy this to backend/.env and fill in real values

# Database (from Render Postgres)
DATABASE_URL=postgresql://username:password@host:5432/dbname

# Redis (Render Redis or skip initially)
REDIS_URL=redis://default:password@host:port

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-minimum-32-chars

# API Keys (get free tiers)
OPENAI_API_KEY=sk-proj-your-openai-key-here
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRICE_PROFESSIONAL=price_xxxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE=price_yyyyyyyyyyyyy

# Email
RESEND_API_KEY=re_your-resend-api-key

# URLs
CLIENT_URL=https://your-frontend-domain.com
API_URL=https://your-backend.onrender.com

# Server
NODE_ENV=production
PORT=5000

