# =============================================================================
# JobAuto - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
# =============================================================================

# ---------------------------- DATABASE ----------------------------
# PostgreSQL connection string (format: postgresql://user:password@host:port/database)
DATABASE_URL=postgresql://jobauto:your_password@localhost:5432/jobauto

# ---------------------------- AUTH ----------------------------
# JWT secrets (generate with: openssl rand -base64 32)
# IMPORTANT: Use different values for production!
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32

# ---------------------------- REDIS ----------------------------
# Redis connection for BullMQ queue
# Local: redis://localhost:6379
# Cloud: Get from Render.com or railway.app
REDIS_URL=redis://localhost:6379

# ---------------------------- OPENAI ----------------------------
# Get from https://platform.openai.com/api-keys
# Optional - AI features won't work without this
OPENAI_API_KEY=

# ---------------------------- STRIPE ----------------------------
# Get from https://dashboard.stripe.com/apikeys
# Required for payment processing
STRIPE_SECRET_KEY=

# Get from https://dashboard.stripe.com/webhooks
# Format: whsec_...
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (get from Stripe Dashboard > Products)
# These are created in Stripe and look like price_xxx
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# ---------------------------- RESEND ----------------------------
# Email sending (https://resend.com)
# Optional - Email features require this
RESEND_API_KEY=

# ---------------------------- JOB PORTAL APIs ----------------------------
# Adzuna API (https://www.adzuna.com/act/api.html)
# Free tier: 1000 requests/month
ADZUNA_APP_ID=
ADZUNA_API_KEY=

# Jooble API (https://jooble.org/api)
# Free tier: 100 requests/month
JOOBLE_API_KEY=

# USAJobs API (https://developer.usajobs.gov/api)
# Requires account approval
USAJOBS_API_KEY=
USAJOBS_AGENCY=

# ---------------------------- APPLICATION ----------------------------
# Frontend URL (for CORS and redirects)
CLIENT_URL=http://localhost:5173

# Server port
PORT=5000

# Node environment
NODE_ENV=development

# ---------------------------- OPTIONAL ----------------------------
# Sentry error tracking (https://sentry.io)
SENTRY_DSN=

# Analytics (PostHog)
POSTHOG_API_KEY=

# ---------------------------- EMAIL (SMTP) - Optional Alternative to Resend ----------------------------
# If not using Resend, configure SMTP for email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
