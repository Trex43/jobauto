# JobAuto Backend - Required Environment Variables
# Copy to .env and fill values

# === REQUIRED ===
DATABASE_URL="postgresql://username:password@localhost:5432/jobauto?schema=public"
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-different-from-jwt-min-32-chars"

# === OPTIONAL Job Portals ===
# Adzuna (1000 free req/mo): https://developer.adzuna.com/
ADZUNA_APP_ID=""
ADZUNA_APP_KEY=""

# LinkedIn (OPTIONAL - skip if empty)
LINKEDIN_ACCESS_TOKEN=""

# === DEVELOPMENT ===
NODE_ENV="development"
PORT=5000
CLIENT_URL="http://localhost:5173"

# === PRODUCTION ===
# DATABASE_URL from Railway/Render/Neon
# CLIENT_URL="https://yourdomain.com"

# Run: cp .env.example .env && prisma migrate dev
